@page "/devices"
@inject ApplicationDbContext context

<PageTitle>Devices</PageTitle>

<style>

    .devices-container {
        padding: 20px;
        color: white;
        background-color: #1b1b1b;
        min-height: 100vh;
    }

    .form-container {
        background: #222;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 30px;
        max-width: 500px;
    }

    .form-group {
        margin-bottom: 15px;
    }

        .form-group label {
            display: block;
            margin-bottom: 5px;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 8px;
            border: none;
            border-radius: 5px;
        }

    .btn {
        padding: 8px 15px;
        border: none;
        cursor: pointer;
        color: white;
        border-radius: 5px;
        margin-right: 5px;
    }

    .btn-primary {
        background: #0d6efd;
    }

        .btn-primary:hover {
            background: #0b5ed7;
        }

    .btn-danger {
        background: #dc3545;
    }

        .btn-danger:hover {
            background: #bb2d3b;
        }

    .devices-table {
        width: 100%;
        border-collapse: collapse;
        background: #222;
    }

        .devices-table th,
        .devices-table td {
            padding: 12px;
            border: 1px solid #444;
            text-align: left;
        }

        .devices-table th {
            background: #111;
        }

    .device-image {
        width: 100px;
        height: 60px;
        object-fit: cover;
    }

    .status-on {
        color: lime;
        font-weight: bold;
    }

    .status-off {
        color: red;
        font-weight: bold;
    }

    .status-standby {
        color: orange;
        font-weight: bold;
    }

</style>

<div class="devices-container">

    <h1>Devices Management</h1>

    <!-- CREATE DEVICE FORM -->
    <div class="form-container">

        <h3>Crear Dispositivo</h3>

        <div class="form-group">
            <label>Nombre</label>
            <input type="text" @bind="newDevice.Name" />
        </div>

        <div class="form-group">
            <label>Dirección IP</label>
            <input type="text" @bind="newDevice.IpAddress" />
        </div>

        @if (newDevice.DeviceType == DeviceType.Transmitter)
        {
            <div class="form-group">
                <label>URL Imagen</label>
                <input type="text" @bind="newDevice.ImageUrl" />
            </div>
        }
        else
        {
            <div class="form-group">
                <label>URL Imagen</label>
                <input type="text" disabled value="No disponible para Receiver" />
            </div>
        }

        <div class="form-group">
            <label>Tipo de dispositivo</label>
            <select @bind="newDevice.DeviceType">
                <option value="@DeviceType.Transmitter">Transmitter</option>
                <option value="@DeviceType.Receiver">Receiver</option>
            </select>
        </div>

        <div class="form-group">
            <label>Estado</label>
            <select @bind="newDevice.Status">
                <option value="@DeviceStatus.On">On</option>
                <option value="@DeviceStatus.Standby">Standby</option>
                <option value="@DeviceStatus.Off">Off</option>
            </select>
        </div>

        <button class="btn btn-primary" @onclick="CreateDevice">
            Crear dispositivo
        </button>

    </div>

    <!-- TABLE -->
    <table class="devices-table">

        <thead>
            <tr>
                <th>Preview</th>
                <th>Nombre</th>
                <th>IP</th>
                <th>Tipo</th>
                <th>Estado</th>
                <th>Opciones</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var device in devices)
            {
                <tr>

                    <!-- IMAGE -->
                    <td>
                        @if (device.DeviceType == DeviceType.Transmitter)
                        {
                            <img src="@device.ImageUrl" class="device-image" />
                        }
                        else
                        {
                            <span>Sin Imagen</span>
                        }
                    </td>

                    <!-- NAME -->
                    <td>
                        @if (editingDeviceId == device.Id)
                        {
                            <input @bind="editingDevice.Name" />
                        }
                        else
                        {
                            @device.Name
                        }
                    </td>

                    <!-- IP -->
                    <td>
                        @if (editingDeviceId == device.Id)
                        {
                            <input @bind="editingDevice.IpAddress" />
                        }
                        else
                        {
                            @device.IpAddress
                        }
                    </td>

                    <!-- TYPE -->
                    <td>
                        @if (editingDeviceId == device.Id)
                        {
                            <span>
                                @editingDevice.DeviceType
                            </span>
                        }
                        else
                        {
                            @device.DeviceType
                        }
                    </td>

                    <!-- STATUS -->
                    <td>
                        @if (editingDeviceId == device.Id)
                        {
                            <select @bind="editingDevice.Status">
                                <option value="@DeviceStatus.On">On</option>
                                <option value="@DeviceStatus.Standby">Standby</option>
                                <option value="@DeviceStatus.Off">Off</option>
                            </select>
                        }
                        else
                        {
                            <span class="@GetStatusClass(device.Status)">
                                @device.Status
                            </span>
                        }
                    </td>

                    <!-- ACTIONS -->
                    <td>

                        @if (editingDeviceId == device.Id)
                        {
                            <button class="btn btn-primary" @onclick="SaveEdit">
                                Save
                            </button>

                            <button class="btn btn-danger" @onclick="CancelEdit">
                                Cancel
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-primary" @onclick="() => StartEdit(device)">
                                Edit
                            </button>

                            <button class="btn btn-danger" @onclick="() => DeleteDevice(device.Id)">
                                Delete
                            </button>
                        }

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

@code {

    private List<Device> devices = new();

    private Device newDevice = new()
    {
        Name = "",
        IpAddress = "",
        ImageUrl = "",
        DeviceType = DeviceType.Transmitter,
        Status = DeviceStatus.On
    };

    // EDIT STATE
    private int? editingDeviceId = null;
    private Device editingDevice = new();

    protected override void OnInitialized()
    {
        LoadDevices();
    }

    private void LoadDevices()
    {
        devices = context.Devices.ToList();
    }

    // CREATE
    private void CreateDevice()
    {
        if (string.IsNullOrWhiteSpace(newDevice.Name))
            return;

        //Aunque lo evite en el frontend, asegurarlo en el backend. Si es un receptor no url de imagen
        if (newDevice.DeviceType == DeviceType.Receiver)
        {
            newDevice.ImageUrl = null;
        }

        context.Devices.Add(newDevice);
        context.SaveChanges();

        LoadDevices();

        newDevice = new Device
        {
            Name = "",
            IpAddress = "",
            ImageUrl = "",
            DeviceType = DeviceType.Transmitter,
            Status = DeviceStatus.On
        };
    }

    // DELETE
    private void DeleteDevice(int deviceId)
    {
        var device = context.Devices.FirstOrDefault(d => d.Id == deviceId);

        if (device == null)
            return;

        var connectionsToDelete = context.Connections
            .Where(c => c.ReceiverId == deviceId || c.TransmitterId == deviceId);

        context.Connections.RemoveRange(connectionsToDelete);

        var profileConnectionsToDelete = context.ProfileConnections
            .Where(pc => pc.ReceiverId == deviceId || pc.TransmitterId == deviceId);

        context.ProfileConnections.RemoveRange(profileConnectionsToDelete);

        context.Devices.Remove(device);

        context.SaveChanges();

        LoadDevices();
    }

    // EDIT START
    private void StartEdit(Device device)
    {
        editingDeviceId = device.Id;

        editingDevice = new Device
        {
            Id = device.Id,
            Name = device.Name,
            IpAddress = device.IpAddress,
            ImageUrl = device.ImageUrl,
            DeviceType = device.DeviceType,
            Status = device.Status
        };
    }

    // EDIT SAVE
    private void SaveEdit()
    {
        var device = context.Devices.FirstOrDefault(d => d.Id == editingDeviceId);

        if (device == null)
            return;

        device.Name = editingDevice.Name;
        device.IpAddress = editingDevice.IpAddress;
        device.ImageUrl = editingDevice.ImageUrl;
        device.DeviceType = editingDevice.DeviceType;
        device.Status = editingDevice.Status;

        context.SaveChanges();

        editingDeviceId = null;
        LoadDevices();
    }

    // EDIT CANCEL
    private void CancelEdit()
    {
        editingDeviceId = null;
    }

    private string GetStatusClass(DeviceStatus status)
    {
        return status switch
        {
            DeviceStatus.On => "status-on",
            DeviceStatus.Off => "status-off",
            DeviceStatus.Standby => "status-standby",
            _ => ""
        };
    }
}