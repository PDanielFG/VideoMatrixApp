@page "/devices"
@inject ApplicationDbContext context

<PageTitle>Devices</PageTitle>

<style>

    .devices-container {
        padding: 20px;
        color: white;
        background-color: #1b1b1b;
        min-height: 100vh;
    }

    .form-container {
        background: #222;
        padding: 20px;
        border-radius: 10px;
        margin-bottom: 30px;
        max-width: 500px;
    }

        .form-container h3 {
            margin-bottom: 20px;
        }

    .form-group {
        margin-bottom: 15px;
    }

        .form-group label {
            display: block;
            margin-bottom: 5px;
        }

        .form-group input,
        .form-group select {
            width: 100%;
            padding: 8px;
            border: none;
            border-radius: 5px;
        }

    .btn {
        padding: 8px 15px;
        border: none;
        cursor: pointer;
        color: white;
        border-radius: 5px;
    }

    .btn-primary {
        background: #0d6efd;
    }

        .btn-primary:hover {
            background: #0b5ed7;
        }

    .btn-danger {
        background: #dc3545;
    }

        .btn-danger:hover {
            background: #bb2d3b;
        }

    .devices-table {
        width: 100%;
        border-collapse: collapse;
        background: #222;
    }

        .devices-table th,
        .devices-table td {
            padding: 12px;
            border: 1px solid #444;
            text-align: left;
        }

        .devices-table th {
            background: #111;
        }

    .device-image {
        width: 100px;
        height: 60px;
        object-fit: cover;
    }

    .status-on {
        color: lime;
        font-weight: bold;
    }

    .status-off {
        color: red;
        font-weight: bold;
    }

    .status-standby {
        color: orange;
        font-weight: bold;
    }

</style>

<div class="devices-container">

    <h1>Devices Management</h1>

    <!-- CREATE DEVICE FORM -->
    <div class="form-container">

        <h3>Create Device</h3>

        <div class="form-group">
            <label>Name</label>

            <input type="text"
                   @bind="newDevice.Name" />
        </div>

        <div class="form-group">
            <label>IP Address</label>

            <input type="text"
                   @bind="newDevice.IpAddress" />
        </div>

        <div class="form-group">
            <label>Image URL</label>

            <input type="text"
                   @bind="newDevice.ImageUrl" />
        </div>

        <div class="form-group">
            <label>Device Type</label>

            <select @bind="newDevice.DeviceType">

                <option value="@DeviceType.Transmitter">
                    Transmitter
                </option>

                <option value="@DeviceType.Receiver">
                    Receiver
                </option>

            </select>
        </div>

        <div class="form-group">
            <label>Status</label>

            <select @bind="newDevice.Status">

                <option value="@DeviceStatus.On">
                    On
                </option>

                <option value="@DeviceStatus.Standby">
                    Standby
                </option>

                <option value="@DeviceStatus.Off">
                    Off
                </option>

            </select>
        </div>

        <button class="btn btn-primary"
                @onclick="CreateDevice">

            Create Device

        </button>

    </div>

    <!-- DEVICES TABLE -->
    <table class="devices-table">

        <thead>

            <tr>

                <th>Preview</th>
                <th>Name</th>
                <th>IP</th>
                <th>Type</th>
                <th>Status</th>
                <th>Actions</th>

            </tr>

        </thead>

        <tbody>

            @foreach (var device in devices)
            {
                <tr>

                    <td>

                        @if (device.DeviceType == DeviceType.Transmitter)
                        {
                            <img src="@device.ImageUrl"
                                 class="device-image" />
                        }
                        else
                        {
                            <span>No Image</span>
                        }

                    </td>

                    <td>@device.Name</td>

                    <td>@device.IpAddress</td>

                    <td>@device.DeviceType</td>

                    <td class="@GetStatusClass(device.Status)">
                        @device.Status
                    </td>

                    <td>

                        <button class="btn btn-danger"
                                @onclick="() => DeleteDevice(device.Id)">

                            Delete

                        </button>

                    </td>

                </tr>
            }

        </tbody>

    </table>

</div>

@code {

    private List<Device> devices = new();

    private Device newDevice = new()
    {
        Name = "",
        IpAddress = "",
        ImageUrl = "",
        DeviceType = DeviceType.Transmitter,
        Status = DeviceStatus.On
    };

    protected override void OnInitialized()
    {
        LoadDevices();
    }

    private void LoadDevices()
    {
        devices = context.Devices.ToList();
    }

    private void CreateDevice()
    {
        if (string.IsNullOrWhiteSpace(newDevice.Name))
            return;

        context.Devices.Add(newDevice);

        context.SaveChanges();

        LoadDevices();

        // Reset form
        newDevice = new Device
        {
            Name = "",
            IpAddress = "",
            ImageUrl = "",
            DeviceType = DeviceType.Transmitter,
            Status = DeviceStatus.On
        };
    }

    private void DeleteDevice(int deviceId)
    {
        var device = context.Devices
            .FirstOrDefault(d => d.Id == deviceId);

        if (device == null)
            return;

        // Remove current connections
        var connectionsToDelete = context.Connections
            .Where(c =>
                c.ReceiverId == deviceId ||
                c.TransmitterId == deviceId);

        context.Connections.RemoveRange(connectionsToDelete);

        // Remove profile connections
        var profileConnectionsToDelete = context.ProfileConnections
            .Where(pc =>
                pc.ReceiverId == deviceId ||
                pc.TransmitterId == deviceId);

        context.ProfileConnections.RemoveRange(profileConnectionsToDelete);

        // Remove device
        context.Devices.Remove(device);

        context.SaveChanges();

        LoadDevices();
    }

    private string GetStatusClass(DeviceStatus status)
    {
        return status switch
        {
            DeviceStatus.On => "status-on",
            DeviceStatus.Off => "status-off",
            DeviceStatus.Standby => "status-standby",
            _ => ""
        };
    }

}