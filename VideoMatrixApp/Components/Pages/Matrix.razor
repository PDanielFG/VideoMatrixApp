@page "/"
@inject ApplicationDbContext context

<PageTitle>Video Matrix</PageTitle>

<style>

    .matrix-container {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background-color: #1b1b1b;
        overflow: hidden;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px;
        background: #1e2a38;
        color: white;
        flex-wrap: wrap;
        gap: 10px;
    }

    .top-bar-controls {
        display: flex;
        gap: 10px;
        align-items: center;
        flex-wrap: wrap;
    }

    .main-content {
        display: flex;
        flex: 1;
        gap: 10px;
        padding: 10px;
        overflow: hidden;
    }

    .matrix-grid {
        flex: 3;
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 10px;
        overflow-y: auto;
        align-content: start;
    }

    .receiver-tile {
        background: black;
        border: 2px solid #444;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        cursor: pointer;
        transition: 0.2s;
        max-height: 350px;
    }

        .receiver-tile:hover {
            border-color: #777;
        }

    .selected {
        border: 3px solid cyan;
    }

    .receiver-header {
        background: #222;
        color: white;
        padding: 5px;
        font-size: 12px;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .connection-info {
        background: #111;
        color: cyan;
        font-size: 12px;
        padding: 4px;
    }

    .video-feed {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
    }

    .no-signal {
        color: red;
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: bold;
    }

    .transmitter-panel {
        flex: 1;
        background: #111;
        color: white;
        padding: 10px;
        overflow-y: auto;
        min-width: 240px;
    }

    .transmitter-item {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
        background: #222;
        padding: 8px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: 0.2s;
    }

        .transmitter-item:hover {
            border-color: cyan;
        }

        .transmitter-item img {
            width: 80px;
            height: 50px;
            object-fit: cover;
        }

    .status-on {
        color: lime;
    }

    .status-off {
        color: red;
    }

    .status-standby {
        color: orange;
    }

    .btn {
        padding: 5px 10px;
        background: #0d6efd;
        color: white;
        border: none;
        cursor: pointer;
    }

        .btn:hover {
            background: #0b5ed7;
        }

    .btn-danger {
        background: #dc3545;
    }

        .btn-danger:hover {
            background: #bb2d3b;
        }

        /* pantalla completa */
    .fullscreen-view {
        position: fixed;
        inset: 0;
        background: black;
        z-index: 9999;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .fullscreen-video {
        width: 100vw;
        height: 100vh;
        object-fit: contain;
    }

    .fullscreen-btn {
        background: #0d6efd;
        border: none;
        color: white;
        cursor: pointer;
        font-size: 12px;
        padding: 4px 8px;
        border-radius: 4px;
        transition: 0.2s;
    }

        .fullscreen-btn:hover {
            background: #0b5ed7;
        }


    /* Responsive. Móvil */
    /* Responsive. Móvil */
    @@media (max-width: 768px) {

        .main-content {
            flex-direction: column;
        }

        .top-bar {
            flex-direction: column;
            align-items: center;
            text-align: center;
        }

        .top-bar-controls {
            flex-direction: column;
            align-items: center;
            justify-content: center;
            width: 100%;
        }

            .top-bar-controls input,
            .top-bar-controls select,
            .top-bar-controls button {
                width: 100%;
                max-width: 320px;
            }

        .profile-row {
            width: 100%;
            display: flex;
            justify-content: center;
        }

            .profile-row select {
                width: 100%;
                max-width: 320px;
            }
    }

    .video-area {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 180px; /* 👈 clave */
    }
</style>

<div class="matrix-container">

    <!-- TOP BAR -->
    <div class="top-bar">

        <h3>Administración matriz de vídeo</h3>

        <!-- PROFILE CONTROLS -->
        <div class="top-bar-controls">

            <!-- PROFILE NAME -->
            <input type="text"
                   placeholder="Nombre perfil"
                   @bind="profileName" />

            <!-- SAVE PROFILE -->
            <button class="btn"
                    @onclick="SaveProfile">
                Guardar perfil
            </button>

            <!-- PROFILE SELECTOR -->
            
            <div class="profile-row">
                <select @bind="selectedProfileId">

                    <option value="0">
                        Selecciona perfil
                    </option>

                    @foreach (var profile in profiles)
                    {
                        <option value="@profile.Id">
                            @profile.Name
                        </option>
                    }

                </select>
            </div>

            <!-- LOAD PROFILE -->
            <button class="btn"
                    @onclick="LoadProfile">
                Cargar perfil
            </button>

            <!-- DELETE PROFILE -->
            <button class="btn btn-danger"
                    @onclick="DeleteProfile">
                Borrar perfil
            </button>

        </div>

    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        
        <!-- RECEIVERS GRID -->
        <div class="matrix-grid">

            @foreach (var receiver in receivers)
            {
                <div class="receiver-tile @(selectedReceiver?.Id == receiver.Id ? "selected" : "")"
                     @onclick="() => SelectReceiver(receiver)"
                     @ondblclick="() => fullscreenReceiver = receiver">

                    <!-- RECEIVER NAME -->
                    <div class="receiver-header">

                        <span>@receiver.Name</span>

                        <button class="fullscreen-btn"
                                @onclick:stopPropagation="true"
                                @onclick="() => fullscreenReceiver = receiver">
                            Pantalla completa
                        </button>

                    </div>

                    <!-- CONNECTED TRANSMITTER -->
                    @if (GetTransmitter(receiver) is Device connectedTx)
                    {
                        <div class="connection-info">
                            Conectado a: @connectedTx.Name
                        </div>
                    }

                    <!-- VIDEO -->
                    <div class="video-area">

                        @if (GetTransmitter(receiver) is Device tx &&
                             tx.Status == DeviceStatus.On)
                        {
                            <img src="@tx.ImageUrl"
                                 class="video-feed" />
                        }
                        else
                        {
                            <div class="no-signal">
                                SIN SEÑAL
                            </div>
                        }

                    </div>

                </div>
            }

        </div>

        <!-- TRANSMITTER PANEL -->
        <div class="transmitter-panel">

            <h4>Transmisores</h4>

            @foreach (var tx in transmitters)
            {
                <div class="transmitter-item"
                     @onclick="() => AssignTransmitter(tx)">

                    <img src="@tx.ImageUrl" />

                    <div>

                        <strong>@tx.Name</strong>

                        <p>@tx.IpAddress</p>

                        <p class="@(GetStatusClass(tx.Status))">
                            @tx.Status
                        </p>

                    </div>

                </div>
            }

        </div>

    </div>

    </div>

    @if (fullscreenReceiver != null)
    {
        <div class="fullscreen-view">

            <button class="btn btn-danger"
                    style="position:absolute;top:20px;right:20px;z-index:10000;"
                    @onclick="() => fullscreenReceiver = null">
                Salir pantalla completa
            </button>

            @{
                var tx = GetTransmitter(fullscreenReceiver);
            }

            @if (tx != null && tx.Status == DeviceStatus.On)
            {
                <img src="@tx.ImageUrl"
                     class="fullscreen-video" />
            }
            else
            {
                <div class="no-signal">
                    SIN SEÑAL
                </div>
            }

        </div>
    }


@code {

    private List<Device> receivers = new();
    private List<Device> transmitters = new();
    private List<Connection> connections = new();

    // Profiles
    private List<Profile> profiles = new();

    // Selected receiver
    private Device? selectedReceiver;

    // Profile name input
    private string profileName = "";

    // Selected profile
    private int selectedProfileId;

    //Pantalla completa 
    private Device? fullscreenReceiver;

    private void ToggleFullscreen(Device receiver)
    {
        if (fullscreenReceiver?.Id == receiver.Id)
            fullscreenReceiver = null;
        else
            fullscreenReceiver = receiver;
    }

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        receivers = context.Devices
         .Where(d => d.DeviceType == DeviceType.Receiver
                  && d.Status == DeviceStatus.On)
         .ToList();

        transmitters = context.Devices
            .Where(d => d.DeviceType == DeviceType.Transmitter)
            .ToList();

        connections = context.Connections.ToList();

        profiles = context.Profiles.ToList();
    }

    private Device? GetTransmitter(Device receiver)
    {
        var connection = connections
            .FirstOrDefault(c => c.ReceiverId == receiver.Id);

        if (connection == null)
            return null;

        return transmitters
            .FirstOrDefault(t => t.Id == connection.TransmitterId);
    }

    private void SelectReceiver(Device receiver)
    {
        selectedReceiver = receiver;
    }

    private void AssignTransmitter(Device transmitter)
    {
        if (selectedReceiver == null)
            return;

        // Remove old connection
        var existingConnection = context.Connections
            .FirstOrDefault(c => c.ReceiverId == selectedReceiver.Id);

        if (existingConnection != null)
        {
            context.Connections.Remove(existingConnection);
        }

        // Create new connection
        var newConnection = new Connection
        {
            ReceiverId = selectedReceiver.Id,
            TransmitterId = transmitter.Id
        };

        context.Connections.Add(newConnection);

        context.SaveChanges();

        // Reload connections
        connections = context.Connections.ToList();
    }

    private void SaveProfile()
    {
        if (string.IsNullOrWhiteSpace(profileName))
            return;

        // Create profile
        var profile = new Profile
        {
            Name = profileName
        };

        context.Profiles.Add(profile);

        context.SaveChanges();

        // Save current connections
        foreach (var connection in connections)
        {
            var profileConnection = new ProfileConnection
            {
                ProfileId = profile.Id,
                ReceiverId = connection.ReceiverId,
                TransmitterId = connection.TransmitterId
            };

            context.ProfileConnections.Add(profileConnection);
        }

        context.SaveChanges();

        // Reload profiles
        profiles = context.Profiles.ToList();

        // Clear input
        profileName = "";
    }

    private void LoadProfile()
    {
        if (selectedProfileId == 0)
            return;

        // Remove current connections
        context.Connections.RemoveRange(context.Connections);

        context.SaveChanges();

        // Get saved profile connections
        var profileConnections = context.ProfileConnections
            .Where(pc => pc.ProfileId == selectedProfileId)
            .ToList();

        // Restore connections
        foreach (var pc in profileConnections)
        {
            var connection = new Connection
            {
                ReceiverId = pc.ReceiverId,
                TransmitterId = pc.TransmitterId
            };

            context.Connections.Add(connection);
        }

        context.SaveChanges();

        // Reload current connections
        connections = context.Connections.ToList();
    }

    private void DeleteProfile()
    {
        if (selectedProfileId == 0)
            return;

        // Get profile
        var profile = context.Profiles
            .FirstOrDefault(p => p.Id == selectedProfileId);

        if (profile == null)
            return;

        // Get profile connections
        var profileConnections = context.ProfileConnections
            .Where(pc => pc.ProfileId == selectedProfileId);

        // Remove profile connections
        context.ProfileConnections.RemoveRange(profileConnections);

        // Remove profile
        context.Profiles.Remove(profile);

        context.SaveChanges();

        // Reload profiles
        profiles = context.Profiles.ToList();

        // Reset selected profile
        selectedProfileId = 0;
    }

    private string GetStatusClass(DeviceStatus status)
    {
        return status switch
        {
            DeviceStatus.On => "status-on",
            DeviceStatus.Off => "status-off",
            DeviceStatus.Standby => "status-standby",
            _ => ""
        };
    }

}