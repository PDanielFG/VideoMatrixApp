@page "/"
@inject ApplicationDbContext context

<PageTitle>Video Matrix</PageTitle>

<style>
    .matrix-container {
        display: flex;
        flex-direction: column;
        height: 100vh;
        background-color: #1b1b1b;
    }

    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px;
        background: #1e2a38;
        color: white;
    }

    .top-bar-controls {
        display: flex;
        gap: 10px;
        align-items: center;
    }

    .main-content {
        display: flex;
        flex: 1;
        gap: 10px;
        padding: 10px;
    }

    .matrix-grid {
        flex: 3;
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 10px;
    }

    .receiver-tile {
        background: black;
        border: 2px solid #444;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        cursor: pointer;
        transition: 0.2s;
    }

        .receiver-tile:hover {
            border-color: #777;
        }

    .selected {
        border: 3px solid cyan;
    }

    .receiver-header {
        background: #222;
        color: white;
        padding: 5px;
        font-size: 12px;
    }

    .connection-info {
        background: #111;
        color: cyan;
        font-size: 12px;
        padding: 4px;
    }

    .video-feed {
        width: 100%;
        flex: 1;
        object-fit: cover;
        min-height: 0;
    }

    .no-signal {
        color: red;
        flex: 1;
        display: flex;
        justify-content: center;
        align-items: center;
        font-weight: bold;
    }

    .transmitter-panel {
        flex: 1;
        background: #111;
        color: white;
        padding: 10px;
        overflow-y: auto;
    }

    .transmitter-item {
        display: flex;
        gap: 10px;
        margin-bottom: 10px;
        background: #222;
        padding: 8px;
        cursor: pointer;
        border: 2px solid transparent;
        transition: 0.2s;
    }

        .transmitter-item:hover {
            border-color: cyan;
        }

        .transmitter-item img {
            width: 80px;
            height: 50px;
            object-fit: cover;
        }

    .status-on {
        color: lime;
    }

    .status-off {
        color: red;
    }

    .status-standby {
        color: orange;
    }

    .btn {
        padding: 5px 10px;
        background: #0d6efd;
        color: white;
        border: none;
        cursor: pointer;
    }

        .btn:hover {
            background: #0b5ed7;
        }
</style>

<div class="matrix-container">

    <div class="top-bar">

        <h3>Video Matrix Control</h3>

        <!-- CONTROLES PERFILES -->
        <div class="top-bar-controls">

            <!-- INPUT NOMBRE PERFIL -->
            <input type="text"
                   placeholder="Profile name"
                   @bind="profileName" />

            <!-- BOTÓN GUARDAR PERFIL -->
            <button class="btn"
                    @onclick="SaveProfile">
                Save Profile
            </button>

            <!-- SELECT DE PERFILES -->
            <select @bind="selectedProfileId">

                <option value="0">
                    Select profile
                </option>

                @foreach (var profile in profiles)
                {
                    <option value="@profile.Id">
                        @profile.Name
                    </option>
                }

            </select>

            <!-- NUEVO: BOTÓN CARGAR PERFIL -->
            <button class="btn"
                    @onclick="LoadProfile">
                Load Profile
            </button>

        </div>

    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">

        <!-- MATRIX GRID -->
        <div class="matrix-grid">

            @foreach (var receiver in receivers)
            {
                <div class="receiver-tile @(selectedReceiver?.Id == receiver.Id ? "selected" : "")"
                     @onclick="() => SelectReceiver(receiver)">

                    <div class="receiver-header">
                        @receiver.Name
                    </div>

                    <!-- MOSTRAR TX CONECTADO -->
                    @if (GetTransmitter(receiver) is Device connectedTx)
                    {
                        <div class="connection-info">
                            Connected to: @connectedTx.Name
                        </div>
                    }

                    @if (GetTransmitter(receiver) is Device tx &&
                   tx.Status == DeviceStatus.On)
                    {
                        <img src="@tx.ImageUrl"
                             class="video-feed" />
                    }
                    else
                    {
                        <div class="no-signal">
                            NO SIGNAL
                        </div>
                    }

                </div>
            }

        </div>

        <!-- TRANSMITTER PANEL -->
        <div class="transmitter-panel">

            <h4>Transmitters</h4>

            @foreach (var tx in transmitters)
            {
                <div class="transmitter-item"
                     @onclick="() => AssignTransmitter(tx)">

                    <img src="@tx.ImageUrl" />

                    <div>

                        <strong>@tx.Name</strong>

                        <p>@tx.IpAddress</p>

                        <p class="@(GetStatusClass(tx.Status))">
                            @tx.Status
                        </p>

                    </div>

                </div>
            }

        </div>

    </div>

</div>

@code {

    private List<Device> receivers = new();
    private List<Device> transmitters = new();
    private List<Connection> connections = new();

    // LISTA DE PERFILES
    private List<Profile> profiles = new();

    // NOMBRE DEL PERFIL
    private string profileName = "";

    // PERFIL SELECCIONADO
    private int selectedProfileId;

    private Device? selectedReceiver;

    protected override void OnInitialized()
    {
        LoadData();
    }

    private void LoadData()
    {
        receivers = context.Devices
          .Where(d => d.DeviceType == DeviceType.Receiver)
          .ToList();

        transmitters = context.Devices
          .Where(d => d.DeviceType == DeviceType.Transmitter)
          .ToList();

        connections = context.Connections.ToList();

        // CARGAR PERFILES
        profiles = context.Profiles.ToList();
    }

    private Device? GetTransmitter(Device receiver)
    {
        var connection = connections
          .FirstOrDefault(c => c.ReceiverId == receiver.Id);

        if (connection == null)
            return null;

        return transmitters
          .FirstOrDefault(t => t.Id == connection.TransmitterId);
    }

    private void SelectReceiver(Device receiver)
    {
        selectedReceiver = receiver;
    }

    private void AssignTransmitter(Device transmitter)
    {
        if (selectedReceiver == null)
            return;

        var existingConnection = context.Connections
          .FirstOrDefault(c => c.ReceiverId == selectedReceiver.Id);

        if (existingConnection != null)
        {
            context.Connections.Remove(existingConnection);
        }

        var newConnection = new Connection
        {
            ReceiverId = selectedReceiver.Id,
            TransmitterId = transmitter.Id
        };

        context.Connections.Add(newConnection);

        context.SaveChanges();

        connections = context.Connections.ToList();
    }

    // GUARDAR PERFIL
    private void SaveProfile()
    {
        // Evitar nombres vacíos
        if (string.IsNullOrWhiteSpace(profileName))
            return;

        // Crear perfil
        var profile = new Profile
        {
            Name = profileName
        };

        context.Profiles.Add(profile);

        context.SaveChanges();

        // Guardar conexiones actuales
        foreach (var connection in connections)
        {
            var profileConnection = new ProfileConnection
            {
                ProfileId = profile.Id,
                ReceiverId = connection.ReceiverId,
                TransmitterId = connection.TransmitterId
            };

            context.ProfileConnections.Add(profileConnection);
        }

        context.SaveChanges();

        // Recargar perfiles
        profiles = context.Profiles.ToList();

        // Limpiar input
        profileName = "";
    }

    // CARGAR PERFIL
    private void LoadProfile()
    {
        if (selectedProfileId == 0)
            return;

        // Borrar conexiones actuales
        context.Connections.RemoveRange(context.Connections);

        context.SaveChanges();

        // Obtener conexiones del perfil
        var profileConnections = context.ProfileConnections
      .Where(pc => pc.ProfileId == selectedProfileId)
      .ToList();

        // Restaurar conexiones
        foreach (var pc in profileConnections)
        {
            var connection = new Connection
            {
                ReceiverId = pc.ReceiverId,
                TransmitterId = pc.TransmitterId
            };

            context.Connections.Add(connection);
        }

        context.SaveChanges();

        // Recargar conexiones
        connections = context.Connections.ToList();
    }

    private string GetStatusClass(DeviceStatus status)
    {
        return status switch
        {
            DeviceStatus.On => "status-on",
            DeviceStatus.Off => "status-off",
            DeviceStatus.Standby => "status-standby",
            _ => ""
        };
    }
}